# Topo — environment variables
# Copy this file to `.env.local` and fill in real values.
#
# ONLY ANTHROPIC_API_KEY is required to run the core loop locally.
# Blob / KV / Sentry are all OPTIONAL in local dev: when their vars are absent,
# lib/store.ts falls back to a local filesystem backend (photos + ledger under
# .topo-data/) and Sentry is a no-op. Set them only for real Vercel deployments.

# --- Required ---------------------------------------------------------------

# Anthropic API key for the Claude extraction + reconciliation call.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude model id used by lib/topoVision.ts. Defaults to a current Claude Sonnet
# model id if unset. Override here if you want to pin a specific snapshot.
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Optional (Vercel Blob + KV — production only) --------------------------
# Local dev uses .topo-data/ on disk by default. Set TOPO_USE_VERCEL_STORAGE=1
# on Vercel (or locally) ONLY when all three credentials below are real.
# TOPO_USE_VERCEL_STORAGE=1
# Without TOPO_USE_VERCEL_STORAGE=1, these are ignored even if present.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx

# --- Optional (Vercel KV — structured commit ledger) ------------------------
# Without these, the ledger is stored as a local JSON file under .topo-data/.
KV_REST_API_URL=https://your-kv-instance.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional (Sentry — observability around sharp + Claude hops) -----------
# Without this, Sentry instrumentation is a no-op.
SENTRY_DSN=https://xxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
